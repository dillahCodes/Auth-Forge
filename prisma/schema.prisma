generator client {
  provider = "prisma-client"
  output   = "../prisma/generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  name                 String
  password             String
  verifiedAt           DateTime?
  sessions             Sessions[]
  emailChangeAuditLogs EmailChangeAuditLog[]
}

model Sessions {
  id           String @id @default(uuid())
  userId       String
  refreshToken String @unique

  userAgent String?

  ipAddress String?

  continent     String?
  country       String?
  countryRegion String?
  city          String?

  latitude  Float?
  longitude Float?

  asn Int?
  isp String?

  replacedBy String?
  revoked    Boolean   @default(false)
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  deletedAt  DateTime?

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailChangeAuditLogs EmailChangeAuditLog[]

  @@index([userId])
}

model EmailChangeAuditLog {
  id String @id @default(uuid())

  userId    String
  sessionId String?

  oldEmail String
  newEmail String

  userAgent String?

  ipAddress String?

  continent     String?
  country       String?
  countryRegion String?
  city          String?

  latitude  Float?
  longitude Float?

  asn Int?
  isp String?

  createdAt DateTime @default(now())

  sessions Sessions? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
}
