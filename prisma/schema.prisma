generator client {
  provider = "prisma-client"
  output   = "../prisma/generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String     @id @default(uuid())
  email      String     @unique
  name       String
  password   String
  verifiedAt DateTime?
  sessions   Sessions[]
}

model Sessions {
  id           String @id @default(uuid())
  userId       String
  refreshToken String @unique

  userAgent String?

  ipAddress String?

  continent     String?
  country       String?
  countryRegion String?
  city          String?

  latitude  Float?
  longitude Float?

  asn Int?
  isp String?

  replacedBy String?
  revoked    Boolean   @default(false)
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  deletedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
